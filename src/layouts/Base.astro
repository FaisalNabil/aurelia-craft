---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
const { title, description, ogImage, ogUrl } = Astro.props;
const base = import.meta.env.BASE_URL;
const siteName = 'Aurelia Craft';
const siteDesc = description || 'বাংলাদেশের নারীদের জন্য সেরা মানের থ্রি-পিস ও শাড়ির এক্সক্লুসিভ কালেকশন।';
const pageTitle = title ? `${title} — ${siteName}` : `${siteName} — থ্রি-পিস ও শাড়ির কালেকশন`;
const pageUrl = ogUrl || 'https://aurelia-craft.vercel.app/';
const pageImg = ogImage || `${base}images/cover.png`;
const year = new Date().getFullYear();
---
<!DOCTYPE html>
<html lang="bn">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={siteDesc} />

  <!-- Open Graph (Facebook preview) -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={siteDesc} />
  <meta property="og:image" content={pageImg} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:url" content={pageUrl} />
  <meta property="og:locale" content="bn_BD" />

  <!-- Twitter card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={siteDesc} />
  <meta name="twitter:image" content={pageImg} />

  <link rel="icon" type="image/jpeg" href={`${base}images/logo.jpg`} />
</head>
<body>

<!-- NAV -->
<nav class="nav">
  <a href={base} class="nav-logo">
    <img src={`${base}images/logo.jpg`} alt="Aurelia Craft" />
  </a>
  <ul class="nav-links">
    <li><a href={base}>হোম</a></li>
    <li><a href={`${base}#threepiece`}>থ্রি-পিস (আনস্টিচড)</a></li>
    <li><a href={`${base}#saree`}>শাড়ি</a></li>
  </ul>
  <a href={`${base}cart/`} class="nav-cart" aria-label="কার্ট">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
      <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
    </svg>
    <span id="cart-badge" class="cart-badge" style="display:none">0</span>
  </a>
</nav>

<!-- PAGE CONTENT -->
<main>
  <slot />
</main>

<!-- FOOTER -->
<footer class="footer">
  <div>
    <div class="footer-logo">
      <img src={`${base}images/logo.jpg`} alt="Aurelia Craft" />
    </div>
    <p class="footer-desc">
      বাংলাদেশের নারীদের জন্য প্রিমিয়াম থ্রি-পিস ও শাড়ির কালেকশন।<br/>প্রতিষ্ঠিত ২০২৩।
    </p>
  </div>
  <div class="footer-col">
    <h6>কালেকশন</h6>
    <a href={`${base}#threepiece`}>থ্রি-পিস (আনস্টিচড)</a>
    <a href={`${base}#saree`}>শাড়ি</a>
    <a href={`${base}catalogue/`}>সম্পূর্ণ কালেকশন</a>
  </div>
  <div class="footer-col">
    <h6>যোগাযোগ</h6>
    <a href="https://facebook.com/aurelia.craft.home" target="_blank" rel="noopener noreferrer">Facebook Page</a>
    <a href="https://wa.me/8801874520327" target="_blank" rel="noopener noreferrer">WhatsApp</a>
    <a href={`${base}cart/`}>কার্ট ও অর্ডার</a>
  </div>
</footer>
<div class="footer-bottom">
  <p>© {year} Aurelia Craft. সর্বস্বত্ব সংরক্ষিত।</p>
  <p style="color: #C4A265;">facebook.com/aurelia.craft.home</p>
</div>

<!-- Global cart utilities (available on all pages) -->
<script>
  // ── Cart helpers ──────────────────────────────────────
  window.AC = window.AC || {};
  window.AC.getCart = () => JSON.parse(localStorage.getItem('ac_cart') || '[]');
  window.AC.saveCart = (cart) => localStorage.setItem('ac_cart', JSON.stringify(cart));
  window.AC.addToCart = (item) => {
    const cart = window.AC.getCart();
    const existing = cart.find(c => c.slug === item.slug);
    if (existing) { existing.qty += 1; } else { cart.push({ ...item, qty: 1 }); }
    window.AC.saveCart(cart);
    window.AC.updateCartBadge();
  };
  window.AC.updateCartBadge = () => {
    const badge = document.getElementById('cart-badge');
    if (!badge) return;
    const total = window.AC.getCart().reduce((s, c) => s + c.qty, 0);
    badge.textContent = total;
    badge.style.display = total > 0 ? 'flex' : 'none';
  };
  // Init badge on load
  window.AC.updateCartBadge();
</script>

<!-- Scroll reveal -->
<script>
  const obs = new IntersectionObserver(
    es => es.forEach(e => { if (e.isIntersecting) e.target.classList.add('vis'); }),
    { threshold: 0.08 }
  );
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
</script>

<Analytics />
</body>
</html>

<style is:global>
.nav-cart {
  position: relative;
  display: flex; align-items: center; justify-content: center;
  color: var(--dark); padding: 6px;
  transition: color var(--tr);
}
.nav-cart:hover { color: var(--brown); }
.cart-badge {
  position: absolute; top: -2px; right: -4px;
  min-width: 18px; height: 18px; padding: 0 4px;
  background: var(--gold); color: var(--dark);
  font-size: 10px; font-weight: 700; font-family: var(--ff-body);
  border-radius: 9px;
  display: flex; align-items: center; justify-content: center;
}
</style>
